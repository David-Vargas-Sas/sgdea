{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "11.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "Dashboard de monitoreo SGDEA — JVM, HTTP, HikariCP y Redis",
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "🔵 HTTP — Latencia y Tasa de Requests",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "reqps"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "id": 2,
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{job=~\"sgdea-.*\"}[1m])) by (application, uri, status)",
          "legendFormat": "{{application}} {{method}} {{uri}} {{status}}",
          "refId": "A"
        }
      ],
      "title": "Tasa de Requests HTTP (req/s)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "s",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "red", "value": 1 }
            ]
          }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "id": 3,
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_server_requests_seconds_bucket{job=~\"sgdea-.*\"}[5m])) by (le, application))",
          "legendFormat": "p99 — {{application}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{job=~\"sgdea-.*\"}[5m])) by (le, application))",
          "legendFormat": "p95 — {{application}}",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_server_requests_seconds_bucket{job=~\"sgdea-.*\"}[5m])) by (le, application))",
          "legendFormat": "p50 — {{application}}",
          "refId": "C"
        }
      ],
      "title": "Latencia HTTP (p50 / p95 / p99)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 10,
      "title": "🟢 JVM — Memoria y CPU",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "bytes", "color": { "mode": "palette-classic" } }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "id": 11,
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{job=~\"sgdea-.*\", area=\"heap\"}",
          "legendFormat": "Heap usado — {{application}}",
          "refId": "A"
        },
        {
          "expr": "jvm_memory_max_bytes{job=~\"sgdea-.*\", area=\"heap\"}",
          "legendFormat": "Heap máx — {{application}}",
          "refId": "B"
        }
      ],
      "title": "JVM — Memoria Heap",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "color": { "mode": "palette-classic" } }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "id": 12,
      "targets": [
        {
          "expr": "process_cpu_usage{job=~\"sgdea-.*\"}",
          "legendFormat": "CPU — {{application}}",
          "refId": "A"
        }
      ],
      "title": "JVM — Uso de CPU",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "id": 20,
      "title": "🟡 HikariCP — Pool de Conexiones BD",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "palette-classic" } }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 19 },
      "id": 21,
      "targets": [
        {
          "expr": "hikaricp_connections_active{job=~\"sgdea-.*\"}",
          "legendFormat": "Activas — {{application}} {{pool}}",
          "refId": "A"
        },
        {
          "expr": "hikaricp_connections_idle{job=~\"sgdea-.*\"}",
          "legendFormat": "Idle — {{application}} {{pool}}",
          "refId": "B"
        },
        {
          "expr": "hikaricp_connections_max{job=~\"sgdea-.*\"}",
          "legendFormat": "Máx — {{application}} {{pool}}",
          "refId": "C"
        }
      ],
      "title": "HikariCP — Conexiones (activas / idle / máx)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5000 },
              { "color": "red", "value": 15000 }
            ]
          }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 19 },
      "id": 22,
      "targets": [
        {
          "expr": "hikaricp_connections_timeout_total{job=~\"sgdea-.*\"}",
          "legendFormat": "Timeouts — {{application}}",
          "refId": "A"
        }
      ],
      "title": "HikariCP — Timeouts de Conexión",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["sgdea", "spring-boot", "microservices"],
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "title": "SGDEA — Microservicios",
  "uid": "sgdea-microservices",
  "version": 1
}

